; ================================================================
; Файл: defs.inc
; Описание: Глобальные определения для проекта
; МК: 1882ВЕ53У (совместим с 8052)
; ================================================================

; --- Подключение стандартных определений 8052 ---
; Устраняет ошибку A10 (повторное определение символов)
$INCLUDE (REG52.INC)

; --- Специфичные регистры 1882ВЕ53У (отсутствуют в REG52.INC) ---
T2CON       DATA    0C8H    ; Управление Таймером 2
RCAP2L      DATA    0CAH    ; Младший байт захвата T2
RCAP2H      DATA    0CBH    ; Старший байт захвата T2
TL2         DATA    0CCH    ; Младший байт счетчика T2
TH2         DATA    0CDH    ; Старший байт счетчика T2
EECON       DATA    096H    ; Регистр управления EEPROM

; --- Биты управления EEPROM (регистр EECON) ---
; Используются для команды №5 (работа с памятью)
EEMEN       EQU     10000000B ; Бит 7: Разрешение доступа к EEPROM (MOVX)
EEMWE       EQU     00010000B ; Бит 4: Разрешение записи
EELD        EQU     00100000B ; Бит 5: Загрузка страницы
RDY_BSY     BIT     EECON.1   ; Бит 1: Готовность (Исправлена ошибка A17)

; --- Константы проекта (Вариант 8) ---
MY_ADDR     EQU     0x08    ; Адрес нашего устройства
BAUD_H      EQU     0FFH    ; Старший байт таймера 2 (9600 бод)
BAUD_L      EQU     0DCH    ; Младший байт таймера 2

; --- Распределение памяти (Internal RAM) ---
; Переменные размещаются в области 30h-7Fh
        DSEG AT 30H
RX_BUFFER:  DS 4    ; Буфер приема пакета (4 байта)
RX_INDEX:   DS 1    ; Текущий индекс принимаемого байта
FLAGS:      DS 1    ; Флаги состояния системы
                    ; Бит 0: 1 = Пакет принят полностью
